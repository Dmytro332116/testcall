# ═══════════════════════════════════════════════════════════════
#  ELEVENLABS AI TELEPHONY SYSTEM — змінні середовища
#  Скопіюй цей файл: cp .env.example .env
#  і заповни своїми даними
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# ELEVENLABS CONVERSATIONAL AI AGENT
# Створіть агента на: https://elevenlabs.io/app/conversational-ai
# ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_AGENT_ID=xxxxxxxxxxxxxxxxxxx

# Перевизначення налаштувань агента (необов'язково)
SYSTEM_PROMPT="Ти — віртуальний оператор компанії. Допомагай клієнтам."
FIRST_MESSAGE="Добрий день! Чим можу допомогти?"
AGENT_LANGUAGE="uk"

# ───────────────────────────────────────────────────────────────
# ASTERISK — AudioSocket (вхідні дзвінки)
# ───────────────────────────────────────────────────────────────
AUDIOSOCKET_PORT=9093
AUDIOSOCKET_HOST=0.0.0.0

# ───────────────────────────────────────────────────────────────
# ASTERISK — AMI (вихідні дзвінки)
# ───────────────────────────────────────────────────────────────
AMI_ENABLED=true
ASTERISK_HOST=127.0.0.1
AMI_PORT=5038
AMI_USER=admin
AMI_SECRET=YOUR_AMI_PASSWORD

# ───────────────────────────────────────────────────────────────
# HTTP API (REST для вихідних дзвінків)
# ───────────────────────────────────────────────────────────────
HTTP_API=true
API_PORT=3000

# ───────────────────────────────────────────────────────────────
# ЛОГУВАННЯ
# ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
