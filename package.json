{
  "name": "ai-voice-telephony",
  "version": "4.0.0",
  "description": "ElevenLabs Conversational AI Telephony System",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "call": "node scripts/make-call.js",
    "docker:build": "docker build -t ai-voice-telephony .",
    "docker:run": "docker run -d --name ai-voice --env-file .env --network host ai-voice-telephony",
    "docker:logs": "docker logs -f ai-voice",
    "docker:stop": "docker stop ai-voice && docker rm ai-voice",
    "compose:up": "docker-compose up -d",
    "compose:down": "docker-compose down",
    "compose:logs": "docker-compose logs -f ai-agent"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "form-data": "^4.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "license": "MIT"
}
